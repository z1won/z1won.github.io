---
// src/pages/portfolio.astro
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.svelte';

const allProjects = [
  {
    title: 'Portfolio Website',
    description: 'Astro와 Svelte로 만든 개인 포트폴리오 및 기술 블로그 웹사이트',
    link: 'https://z1won.github.io',
    github: 'https://github.com/z1won/z1won.github.io',
    tags: ['Astro', 'Svelte', 'GitHub Pages'],
    image: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=500&h=300&fit=crop'
  }
  // 추가하고 싶은 프로젝트가 있다면 여기에 객체 형태로 계속 추가하면 됩니다!
];
---

<Layout title="Portfolio" description="z1won's Projects and Works">
  <div class="portfolio-container">
    <div class="portfolio-header">
      <h1>Projects</h1>
      <p>그동안 빌드해온 토이 프로젝트와 오픈소스 작업물입니다</p>
    </div>

    <!-- 2026 플랫 가이드: 정돈된 보더 격자 배치 -->
    <div class="grid grid-2">
      {allProjects.map(project => (
        <ProjectCard
          client:load
          title={project.title}
          description={project.description}
          link={project.link}
          github={project.github}
          tags={project.tags}
          image={project.image}
        />
      ))}
    </div>
  </div>
</Layout>

<style>
  .portfolio-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .portfolio-header {
    text-align: left;
    margin-bottom: 3rem;
    border-bottom: 1px solid #2a2a30;
    padding-bottom: 2rem;
  }

  .portfolio-header h1 {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
    color: #f4f4f5;
  }

  .portfolio-header p {
    font-size: 1.1rem;
    color: #a1a1aa;
  }
</style>
