---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.svelte';

const allProjects = [
  {
    title: 'Portfolio Website',
    description: 'Astro와 Svelte로 만든 개인 포트폴리오 및 기술 블로그 웹사이트',
    link: 'https://z1won.github.io',
    github: 'https://github.com/z1won/z1won.github.io',
    tags: ['Astro', 'Svelte', 'GitHub Pages', 'CSS'],
    image: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=500&h=300&fit=crop'
  },
  {
    title: 'Project 2',
    description: '여기에 프로젝트 설명을 추가하세요',
    link: '#',
    github: '#',
    tags: ['Tag1', 'Tag2'],
    image: 'https://images.unsplash.com/photo-1555099962-4199c1a92f10?w=500&h=300&fit=crop'
  },
  {
    title: 'Project 3',
    description: '여기에 프로젝트 설명을 추가하세요',
    link: '#',
    github: '#',
    tags: ['Tag1', 'Tag2'],
    image: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=500&h=300&fit=crop'
  }
];
---

<Layout title="Portfolio" description="z1won's projects and portfolio">
  <div class="portfolio-hero">
    <h1>My Projects</h1>
    <p>다양한 기술을 활용한 프로젝트들을 소개합니다</p>
  </div>

  <div class="grid grid-2">
    {allProjects.map(project => (
      <ProjectCard
        client:load
        title={project.title}
        description={project.description}
        link={project.link}
        github={project.github}
        tags={project.tags}
        image={project.image}
      />
    ))}
  </div>
</Layout>

<style>
  .portfolio-hero {
    text-align: center;
    margin-bottom: 4rem;
  }

  .portfolio-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #06b6d4, #3b82f6);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .portfolio-hero p {
    font-size: 1.2rem;
    color: #cbd5e1;
  }
</style>
