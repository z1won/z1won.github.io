---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  return [
    { params: { slug: 'astro-svelte-portfolio' } },
    { params: { slug: 'deploy-github-pages' } },
    { params: { slug: 'web-performance-optimization' } },
  ];
}

const { slug } = Astro.params;

const posts: Record<string, any> = {
  'astro-svelte-portfolio': {
    title: 'Astro와 Svelte로 포트폴리오 만들기',
    date: '2026-06-20',
    category: 'Tutorial',
    author: 'z1won',
    readTime: '10 min',
    content: `
<h1>Astro와 Svelte로 포트폴리오 만들기</h1>
<h2>소개</h2>
<p>Astro와 Svelte를 조합하면 매우 빠르고 대화형인 웹사이트를 만들 수 있습니다.</p>
<h3>주요 특징</h3>
<ul>
  <li><strong>초고속</strong>: Zero JavaScript by default</li>
  <li><strong>현대적</strong>: 최신 웹 기술 활용</li>
  <li><strong>SEO 친화</strong>: 정적 HTML 생성</li>
  <li><strong>개발 경험</strong>: 뛰어난 DX</li>
</ul>
<h2>시작하기</h2>
<p>여기에 더 많은 내용을 작성하세요...</p>
    `
  },
  'deploy-github-pages': {
    title: 'GitHub Pages에 정적 사이트 배포하기',
    date: '2026-06-19',
    category: 'DevOps',
    author: 'z1won',
    readTime: '8 min',
    content: `
<h1>GitHub Pages에 정적 사이트 배포하기</h1>
<h2>개요</h2>
<p>GitHub Pages를 사용하면 무료로 정적 웹사이트를 호스팅할 수 있습니다.</p>
<h2>배포 과정</h2>
<p>자세한 내용을 여기에 작성하세요...</p>
    `
  },
  'web-performance-optimization': {
    title: '웹 성능 최적화: Core Web Vitals 개선하기',
    date: '2026-06-18',
    category: 'Performance',
    author: 'z1won',
    readTime: '12 min',
    content: `
<h1>웹 성능 최적화: Core Web Vitals 개선하기</h1>
<h2>Core Web Vitals란?</h2>
<p>Core Web Vitals은 Google에서 정의한 웹 성능 지표입니다.</p>
<h3>세 가지 핵심 지표</h3>
<ol>
  <li><strong>LCP (Largest Contentful Paint)</strong>: 로딩 성능</li>
  <li><strong>FID (First Input Delay)</strong>: 상호작용 반응성</li>
  <li><strong>CLS (Cumulative Layout Shift)</strong>: 시각적 안정성</li>
</ol>
<h2>최적화 방법</h2>
<p>자세한 내용을 여기에 작성하세요...</p>
    `
  }
};

const post = posts[slug];

if (!post) {
  return Astro.redirect('/blog');
}
---

<Layout title={post.title} description={post.title}>
  <article class="blog-post">
    <header class="post-header">
      <h1>{post.title}</h1>
      <div class="post-meta">
        <span class="date">{new Date(post.date).toLocaleDateString('ko-KR')}</span>
        <span class="separator">/</span>
        <span class="category">{post.category}</span>
        <span class="separator">/</span>
        <span class="read-time">{post.readTime}</span>
      </div>
    </header>

    <div class="post-content" set:html={post.content}></div>

    <footer class="post-footer">
      <p class="author">Written by {post.author}</p>
      <p class="back-link-wrapper">
        <a href="/blog" class="back-link">← 목록으로 돌아가기</a>
      </p>
    </footer>
  </article>
</Layout>

<style>
  .blog-post {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  /* 헤더: 그라데이션 제거, 플랫한 타이포그래피 강조 */
  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #2a2a30;
  }

  .post-header h1 {
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 1.25rem 0;
    color: #f4f4f5;
  }

  .post-meta {
    display: flex;
    gap: 0.75rem;
    color: #a1a1aa;
    font-size: 0.9rem;
    font-weight: 500;
    align-items: center;
  }

  .separator {
    color: #3f3f46;
  }

  /* 본문 콘텐츠 스타일 플랫화 */
  .post-content {
    margin: 2.5rem 0;
    color: #cbd5e1;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  :global(.post-content h1) {
    display: none;
  }

  :global(.post-content h2) {
    color: #06b6d4;
    margin: 3rem 0 1.25rem 0;
    font-size: 1.6rem;
    font-weight: 700;
  }

  :global(.post-content h3) {
    color: #f4f4f5;
    margin: 2rem 0 1rem 0;
    font-size: 1.25rem;
    font-weight: 700;
  }

  :global(.post-content p) {
    margin: 1.25rem 0;
  }

  :global(.post-content ul),
  :global(.post-content ol) {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }

  :global(.post-content li) {
    margin: 0.5rem 0;
  }

  /* 코드 블록 스킨 리뉴얼 */
   Aurora 느낌의 백그라운드를 깔끔한 다크 플랫 보더 블록으로 통일 */
  :global(.post-content code) {
    background: #1a1a1e;
    border: 1px solid #2a2a30;
    border-radius: 4px;
    padding: 0.2rem 0.4rem;
    color: #ea580c;
    font-size: 0.9em;
  }

  :global(.post-content pre) {
    background: #1a1a1e;
    border: 1px solid #2a2a30;
    border-radius: 4px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  /* 푸터 영역 마감 */
  .post-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid #2a2a30;
  }

  .author {
    color: #71717a;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .back-link-wrapper {
    margin-top: 2rem !important;
  }

  .back-link {
    color: #06b6d4;
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: #22d3ee;
    text-decoration: underline;
  }
</style>
